# ─── App ────────────────────────────────────────────
APP_NAME=FlowServe
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# ─── Database ───────────────────────────────────────
# Postgres connection string. For local dev, use:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flowserve

# ─── Auth ───────────────────────────────────────────
# Use `python -c "import secrets; print(secrets.token_urlsafe(48))"` to generate
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Stripe ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── SendGrid ───────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@flowserve.app

# ─── CORS ───────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
